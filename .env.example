NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SHOW_AD_PLACEHOLDERS=true

# Production example:
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# NEXT_PUBLIC_SHOW_AD_PLACEHOLDERS=false

# Supabase Auth uses the current request origin for redirects in local development.
# In Supabase Dashboard > Authentication > URL Configuration, add:
# http://localhost:3000/auth/callback
# http://localhost:3000/en/dashboard
# http://localhost:3000/es/dashboard
# http://localhost:3000/en/update-password
# http://localhost:3000/es/update-password

# Do not expose the Supabase service role key in frontend code or NEXT_PUBLIC variables.
